# ── Slack ──────────────────────────────────────────────
# Bot token from https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-token-here

# Comma-separated channel IDs to scrape (right-click channel → Copy link → last part is the ID)
# Example: C0123ABCDEF,C9876ZYXWVU
SOURCE_CHANNEL_IDS=C0123ABCDEF,C9876ZYXWVU

# The channel where the digest is posted (your VA's channel)
DIGEST_CHANNEL_ID=C0000VACHA

# ── Anthropic ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Optional ────────────────────────────────────────────
# Cron schedule in UTC. Oslo is UTC+2 (summer) / UTC+1 (winter)
# Default below = 06:00 UTC = 08:00 Oslo summer time
CRON_SCHEDULE=0 6 * * *

# How many hours back to look (default 24)
LOOKBACK_HOURS=24
